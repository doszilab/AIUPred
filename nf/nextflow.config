// Path to nf assets. Overridden by root nextflow.config for `nextflow run .`.
params.nf_assets = params.nf_assets ?: projectDir

includeConfig 'conf/base.config'

params {
    input = null
    outdir = 'results'
    aiupred {
        binding = false
        linker = false
        redox = false
        gpu = 0
        force_cpu = false
    }
}

profiles {
    conda {
        conda.enabled = true
        process.conda = "${params.nf_assets}/env/aiupred.yml"
    }
    docker {
        docker.enabled = true
        // CUDA-capable image: uses GPU when visible to the container; otherwise PyTorch falls back to CPU.
        process.container = 'ghcr.io/doszilab/aiupred:gpu'
    }
    docker_gpu {
        docker.enabled = true
        process {
            withName: 'AIUPRED' {
                label = 'gpu'
                container = 'ghcr.io/doszilab/aiupred:gpu'
                containerOptions = '--gpus all'
            }
        }
    }
    gpu {
        docker.enabled = true
        process {
            withName: 'AIUPRED' {
                label = 'gpu'
                container = 'ghcr.io/doszilab/aiupred:gpu'
                containerOptions = '--gpus all'
            }
        }
    }
    docker_cpu {
        docker.enabled = true
        process.container = 'ghcr.io/doszilab/aiupred:cpu'
        params.aiupred.force_cpu = true
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
        process.container = 'docker://ghcr.io/doszilab/aiupred:cpu'
    }
    singularity_gpu {
        singularity.enabled = true
        singularity.autoMounts = true
        singularity.runOptions = '--nv'
        process {
            withName: 'AIUPRED' {
                label = 'gpu'
                container = 'docker://ghcr.io/doszilab/aiupred:gpu'
            }
        }
    }
    test {
        params.input = "${params.nf_assets}/tests/data/test.fasta"
        params.outdir = "${params.nf_assets}/tests/results"
    }
    cpu {
        params.aiupred.force_cpu = true
    }
}
